# Exclude version control and documentation from the Docker build context.
.git
.gitignore
*.md
LICENSE

# Exclude discovery/blocked capture artifacts.
.agent-discovery
.agent-blocked

# Exclude the fragment directories — only the assembled allowlist-*.txt files
# are needed inside the image (generated by build.sh).
allowlist-domains.d
allowlist-proxy-domains.d
allowlist-cidrs.d

# Exclude sandbox.conf — it's only read by runme.sh on the host, not inside the image.
sandbox.conf

# Exclude project management tooling — host-side only, not needed in the image.
projects.conf
projects.conf.example
project-init.sh
sync-to-projects.sh

# Exclude the seed helper Dockerfile — used only by repo.sh on the host to build
# a separate lightweight image, never part of the sandbox image build.
Dockerfile.seed