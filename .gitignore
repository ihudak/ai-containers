/.idea/
/.remember/

# Personal/local Claude Code settings (a shared .claude/settings.json may still be committed)
.claude/settings.local.json

# Editor swap/temp files
*.swp
*.swo
.DS_Store

# Agent outputs written to the launch directory by sandbox.sh (restricted/discovery).
.agent-blocked/
.agent-discovery/

# Generated by build.sh — edit the *.d/ fragment directories instead
/allowlist-domains.txt
/allowlist-proxy-domains.txt
/allowlist-cidrs.txt

# User-specific custom allowlist entries — may contain internal hostnames.
# Copy the .example files to get started:
#   cp allowlist-domains.d/custom.txt.example allowlist-domains.d/custom.txt
#   cp allowlist-proxy-domains.d/custom.txt.example allowlist-proxy-domains.d/custom.txt
#   cp allowlist-cidrs.d/custom.txt.example allowlist-cidrs.d/custom.txt
allowlist-domains.d/custom.txt
allowlist-proxy-domains.d/custom.txt
allowlist-cidrs.d/custom.txt

# Project registry — populated by project-init.sh. Gitignored to avoid
# committing personal paths. See projects.conf.example for the format.
/projects.conf